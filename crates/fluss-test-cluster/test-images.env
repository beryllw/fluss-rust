FLUSS_IMAGE=apache/fluss
FLUSS_VERSION=0.9.1-incubating
ZOOKEEPER_IMAGE=zookeeper
ZOOKEEPER_VERSION=3.9.2
# Lakehouse (Paimon) e2e: RustFS S3-compatible store, mc to create the bucket,
# and the Fluss quickstart Flink image that bundles the tiering job jar. All
# pinned to the same Fluss line (0.9.1-incubating) per the official lakehouse
# quickstart. PAIMON_S3_VERSION is the paimon-s3 plugin the Fluss servers mount.
RUSTFS_IMAGE=rustfs/rustfs
RUSTFS_VERSION=latest
MC_IMAGE=minio/mc
MC_VERSION=latest
FLUSS_FLINK_IMAGE=apache/fluss-quickstart-flink
FLUSS_FLINK_VERSION=1.20-0.9.1-incubating-rc1
PAIMON_S3_VERSION=1.3.1
